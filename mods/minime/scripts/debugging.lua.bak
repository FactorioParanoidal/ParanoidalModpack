log("Entered file " .. debug.getinfo(1).source)

local debugging = {}

------------------------------------------------------------------------------------
-- Make it easier to add quotation marks to strings
local quote = "\""

debugging.enquote = function(text)
  return quote..text..quote
end

------------------------------------------------------------------------------------
-- Enable writing to log file until startup options are set, so debugging output
-- from the start of a game session can be logged. This depends on a locally
-- installed dummy mod to allow debugging output during development without
-- spamming real users.
local debug_to_log = settings.startup["minime_debug_to_log"] and
                      settings.startup["minime_debug_to_log"].value
local debug_to_game = settings.startup["minime_debug_to_game"] and
                      settings.startup["minime_debug_to_game"].value

debugging.is_debug = (mods and mods["_debug"]) or (script and script.active_mods["_debug"]) or
                  debug_to_log or debug_to_game


------------------------------------------------------------------------------------
--                               DEBUGGING FUNCTIONS                              --
------------------------------------------------------------------------------------


------------------------------------------------------------------------------------
-- Make a reverse look-up list for event names
if script then
debugging.event_names = {}
for event, e in pairs(defines.events) do
  debugging.event_names[e] = event
end
debugging.event_names["on_load"] = "on_load"
debugging.event_names["on_init"] = "on_init"
debugging.event_names["on_configuration_changed"] = "on_configuration_changed"

  debugging.event_names["on_nth_tick"] = "on_nth_tick"
end

------------------------------------------------------------------------------------
-- Make a reverse look-up list for controller names
if script then
debugging.controller_names = {}
for name, index in pairs(defines.controllers) do
  debugging.controller_names[index] = name
end
end

------------------------------------------------------------------------------------
-- Make a reverse look-up list for mouse-button names
if script then
  debugging.mouse_button_names = {}
  for name, index in pairs(defines.mouse_button_type) do
    debugging.mouse_button_names[index] = name
  end
end

------------------------------------------------------------------------------------
-- Make a reverse look-up list for entity status names
if script then
  debugging.entity_status = {}
  for name, index in pairs(defines.entity_status) do
    debugging.entity_status[index] = name
  end
end

