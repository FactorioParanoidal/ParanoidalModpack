log("Entered file "..debug.getinfo(1).source)

local debugging = {}

local debug_default = false


-- TODO: This shouldn't be in debugging.lua!
------------------------------------------------------------------------------------
-- Make it easier to add quotation marks to strings
local quote = "\""

debugging.enquote = function(text)
  return quote..text..quote
end


------------------------------------------------------------------------------------
-- Enable writing to log file until startup options are set, so debugging output
-- from the start of a game session can be logged. This depends on a locally
-- installed dummy mod to allow debugging output during development without
-- spamming real users.
-- If you don't have this mod or don't want to activate it, you can also change
-- the value of debug_default!
debugging.debug_in_log =  (mods and mods["_debug"] and true) or
                          (script and script.active_mods["_debug"] and true) or
                          (settings.startup["minime_debug_to_log"] and
                            settings.startup["minime_debug_to_log"].value) or
                          debug_default

debugging.is_debug = debugging.debug_in_log
--~ debugging.is_debug = false



debugging.set_debug_state = function(debug_state)
  -- We only change debug_state if logging is allowed at all (depending on presence
  -- of mod "_debug" or setting)
  if debugging.debug_in_log and debug_state ~= nil then
    debugging.is_debug = debug_state
  end
end

